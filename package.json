{
  "name": "api-testing-jsonplaceholder",
  "version": "1.0.0",
  "description": "API test automation suite for JSONPlaceholder using Supertest, Mocha and Chai",
  "scripts": {
    "test": "mocha",
    "test:posts": "mocha tests/posts.test.js",
    "test:users": "mocha tests/users.test.js",
    "test:comments": "mocha tests/comments.test.js",
    "test:todos": "mocha tests/todos.test.js",
    "test:report": "mocha --reporter mochawesome --reporter-options reportDir=mochawesome-report,reportFilename=test-report"
  },
  "keywords": [
    "api-testing",
    "supertest",
    "mocha",
    "chai",
    "qa",
    "automation"
  ],
  "author": "Julieta Entivero",
  "license": "MIT",
  "devDependencies": {
    "chai": "^4.3.10",
    "mocha": "^10.2.0",
    "mochawesome": "^7.1.3",
    "supertest": "^6.3.3"
  }
}
